{
  "schema": "project-telos.browser-evidence-smoke/v1",
  "source_packet": "demo/integrations/browser-evidence.json",
  "pipeline_consumers": [
    "gather.browser-evidence",
    "index.browser_evidence_refs",
    "forum.project-telos-route",
    "crucible.verify_browser_evidence",
    "learn.evidenceRef",
    "emet.anchor-recipe",
    "buildlang.editor-fixture"
  ],
  "council_route": {
    "local_first": true,
    "route_surfaces": [
      "index.context-envelope",
      "forum.project-telos-route"
    ],
    "policy": "preserve refs and hashes locally; route richer browser context to council/review only when uncertainty, complexity, or operator intent justifies model overhead"
  },
  "overhead_metrics": {
    "default_model_payload": "refs-only",
    "council_payload": "on-demand dereference of selected evidence refs",
    "tracked": [
      "tokens_spent",
      "council_calls",
      "artifact_dereferences",
      "route_confidence",
      "match_rate",
      "drift_rate",
      "unverifiable_rate"
    ]
  },
  "verdict": "MATCH"
}
