{
  "schema": "project-telos.context-envelope/v1",
  "verified_on": "2026-06-27",
  "purpose": "Define the Project Telos large-workspace context contract: compact enough for agent use, exact enough for replay, and readable enough for unattended engineering review.",
  "sources_checked": [
    {
      "name": "MCP 2025-06-18 base protocol",
      "url": "https://modelcontextprotocol.io/specification/2025-06-18/basic"
    },
    {
      "name": "MCP 2025-06-18 tools and structured content",
      "url": "https://modelcontextprotocol.io/specification/2025-06-18/server/tools"
    },
    {
      "name": "OpenAI Agents SDK MCP transports",
      "url": "https://openai.github.io/openai-agents-python/mcp/"
    },
    {
      "name": "Claude Code MCP reference",
      "url": "https://code.claude.com/docs/en/mcp"
    },
    {
      "name": "Claude context windows and compaction",
      "url": "https://platform.claude.com/docs/en/build-with-claude/context-windows"
    },
    {
      "name": "Anthropic effective context engineering",
      "url": "https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents"
    },
    {
      "name": "Anthropic long-running agent harnesses",
      "url": "https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents"
    },
    {
      "name": "LLMLingua prompt compression",
      "url": "https://arxiv.org/abs/2310.05736"
    },
    {
      "name": "LLMLingua-2 task-agnostic prompt compression",
      "url": "https://arxiv.org/abs/2403.12968"
    },
    {
      "name": "Prompt compression in the wild",
      "url": "https://arxiv.org/abs/2604.02985"
    }
  ],
  "contract": {
    "authoritative_context": "hash-addressed source refs, expansion commands, freshness checks, and receipt-chain records",
    "model_visible_context": "compact summaries, ranked symbols, invariants, and task-local slices",
    "compression_mode": "semantic extractive compression with replayable source anchors",
    "lossless_requirement": "claims are lossless through source refs and hashes, not through the compressed prose itself",
    "hidden_payloads_allowed": false,
    "steganography_allowed_for": [
      "non-authoritative watermark",
      "pack identifier embedded in rendered artifacts"
    ],
    "steganography_for_required_context_allowed": false,
    "reason": "Required context must remain inspectable by humans, MCP hosts, audit tools, and future agents. Hidden payloads are not a reliable or reviewable source of truth."
  },
  "packet_kinds": [
    "workspace_map",
    "symbol_slice",
    "decision_ledger",
    "proof_slice",
    "expanded_source_ref",
    "diff_receipt",
    "test_receipt",
    "readability_gate",
    "freshness_gate"
  ],
  "required_fields": [
    "envelope_id",
    "workspace.root_hash",
    "workspace.git_head",
    "context_budget.max_input_tokens",
    "context_budget.target_packet_tokens",
    "compression.strategy",
    "compression.ratio_target",
    "compression.lossless_by_ref",
    "source_refs[].path",
    "source_refs[].range",
    "source_refs[].content_hash",
    "source_refs[].expansion_command",
    "summary.claims[].text",
    "summary.claims[].source_ref_ids",
    "receipt_chain[].tool",
    "receipt_chain[].receipt_hash",
    "quality_gates.readability",
    "quality_gates.test_evidence",
    "failure_code"
  ],
  "failure_codes": [
    "stale_context",
    "lossy_summary",
    "missing_source_ref",
    "unexpanded_required_ref",
    "unjoinable_receipt",
    "readability_regression",
    "quality_gate_missing",
    "budget_exceeded",
    "relevance_accounting_missing",
    "raw_context_leak"
  ],
  "flagship_roles": {
    "gather": [
      "ingest source documents and external research",
      "attach provenance receipts"
    ],
    "index": [
      "map repos, symbols, dependencies, and docs",
      "emit compact context packs with source anchors"
    ],
    "forum": [
      "route work to the right agent lane",
      "maintain progress ledgers and human-readable handoffs"
    ],
    "crucible": [
      "verify claims, tests, and invariants",
      "return MATCH, DRIFT, or UNVERIFIABLE"
    ],
    "telos": [
      "join packets, receipts, admissions, and execution spans",
      "enforce host-neutral MCP and CLI presentation"
    ]
  },
  "quality_gates": {
    "readability": [
      "prefer small named helpers over dense inline logic",
      "preserve the local style and public interfaces unless the receipt explains the change",
      "name intermediate values after domain concepts instead of implementation trivia",
      "comment only invariants, protocol boundaries, and non-obvious tradeoffs",
      "avoid clever token-saving code if it makes the next agent slower or less reliable"
    ],
    "large_workspace": [
      "start from an index workspace map before editing",
      "expand exact source refs before changing code",
      "write a progress receipt before ending an unattended run",
      "record tests that prove the claimed behavior",
      "mark unverifiable context explicitly instead of guessing"
    ],
    "unattended_agent": [
      "choose one bounded work item at a time",
      "leave git status, changed files, tests, and next action in the ledger",
      "fail closed when source refs are stale or missing",
      "separate admission decisions from verification verdicts"
    ]
  },
  "workflow": [
    {
      "step": "map",
      "tool": "index.map",
      "output": "workspace_map"
    },
    {
      "step": "pack",
      "tool": "index.context",
      "output": "symbol_slice"
    },
    {
      "step": "ingest",
      "tool": "gather.docs",
      "output": "source receipts"
    },
    {
      "step": "route",
      "tool": "forum.route",
      "output": "agent lane and ledger entry"
    },
    {
      "step": "verify",
      "tool": "crucible.assess",
      "output": "MATCH, DRIFT, or UNVERIFIABLE"
    },
    {
      "step": "join",
      "tool": "telos.context.envelope",
      "output": "context envelope and receipt chain"
    }
  ],
