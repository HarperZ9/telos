{
  "schema": "project-telos.mcp-server-manifest/v1",
  "verified_on": "2026-06-28",
  "workspace_placeholder": "${PROJECT_TELOS_PUBLIC}",
  "transports": [
    "stdio"
  ],
  "profiles": [
    "source_checkout",
    "package"
  ],
  "hosts": {
    "codex": {
      "config_key": "mcp_servers",
      "format": "toml",
      "notes": "Use one [mcp_servers.<name>] table per flagship server."
    },
    "claude": {
      "container_key": "mcpServers",
      "format": "json",
      "notes": "Use one stdio server entry per flagship server."
    },
    "openai_agents": {
      "transport": "stdio",
      "notes": "Mount these commands through the Agents SDK MCP stdio server wrapper."
    },
    "openai_apps": {
      "transport": "mcp",
      "notes": "Register the same tools through an MCP server and render Telos receipts in the app UI."
    }
  },
  "sources": [
    {
      "name": "MCP 2025-06-18 specification",
      "url": "https://modelcontextprotocol.io/specification/2025-06-18"
    },
    {
      "name": "OpenAI Agents SDK MCP",
      "url": "https://openai.github.io/openai-agents-python/mcp/"
    },
    {
      "name": "OpenAI Apps SDK MCP server guide",
      "url": "https://developers.openai.com/apps-sdk/build/mcp-server"
    },
    {
      "name": "Anthropic Claude Code MCP",
      "url": "https://docs.anthropic.com/en/docs/claude-code/mcp"
    }
  ],
  "servers": {
    "gather": {
      "flagship": "gather",
      "description": "Project Telos research intake and provenance server.",
      "expected_tools": [
        "gather.status",
        "gather.doctor",
        "gather.docs",
        "gather.arxiv",
        "gather.run"
      ],
      "freshness": {
        "status_tool": "gather.status",
        "expected_version": "1.5.0",
        "expected_current_status": "1.5.0 completion floor with Project Telos operator-spine MCP parity",
        "failure_codes": [
          "stale_mcp_server",
          "tool_surface_drift",
          "version_drift",
          "behavior_probe_drift",
          "launch_profile_unresolved",
          "freshness_probe_unavailable"
        ]
      },
      "profiles": {
        "source_checkout": {
          "command": "python",
          "args": [
            "-m",
            "gather.cli",
            "mcp"
          ],
          "cwd": "${PROJECT_TELOS_PUBLIC}/gather",
          "env": {
            "PYTHONPATH": "${PROJECT_TELOS_PUBLIC}/gather/src"
          }
        },
        "package": {
          "command": "gather",
          "args": [
            "mcp"
          ]
        }
      }
    },
    "crucible": {
      "flagship": "crucible",
      "description": "Project Telos falsifiable verification and recheck server.",
      "expected_tools": [
        "crucible.status",
        "crucible.doctor",
        "crucible.assess",
        "crucible.recheck",
        "crucible.run",
        "crucible.measurement_gate",
        "crucible.review",
        "crucible.report",
        "crucible.batch",
        "crucible.registry",
        "crucible.drift",
        "crucible.refine",
        "crucible.verdicts"
      ],
      "freshness": {
        "status_tool": "crucible.status",
        "expected_version": "1.1.0",
        "expected_current_status": "1.1.0 operator floor with run, review, recheck, and MCP parity",
        "failure_codes": [
          "stale_mcp_server",
          "tool_surface_drift",
          "version_drift",
          "behavior_probe_drift",
          "launch_profile_unresolved",
          "freshness_probe_unavailable"
        ]
      },
      "profiles": {
        "source_checkout": {
          "command": "python",
          "args": [
            "-m",
            "crucible.cli",
            "mcp"
          ],
          "cwd": "${PROJECT_TELOS_PUBLIC}/crucible",
          "env": {
            "PYTHONPATH": "${PROJECT_TELOS_PUBLIC}/crucible/src"
          }
        },
        "package": {
          "command": "crucible",
          "args": [
            "mcp"
          ]
        }
      }
    },
    "index": {
      "flagship": "index",
      "description": "Project Telos workspace structure and context server.",
      "expected_tools": [
        "index.map",
        "index.context",
        "index.context.envelope",
        "index.status",
        "index.doctor"
      ],
      "auxiliary_tools": [
        "index_graph",
        "index_focus",
        "index_verify",
        "index_router",
        "index_internals"
      ],
      "freshness": {
        "status_tool": "index.status",
        "expected_version": "2.8.0",
        "expected_current_status": "2.8.0 workspace atlas, certificates, freshness, benchmarking, selection-aware context envelopes, and MCP parity",
        "failure_codes": [
          "stale_mcp_server",
          "tool_surface_drift",
          "version_drift",
          "behavior_probe_drift",
          "launch_profile_unresolved",
          "freshness_probe_unavailable"
        ],
        "behavior_probes": [
          {
            "id": "index-context-envelope-selection-freshness",
            "tool": "index.context.envelope",
            "arguments": {
              "root": "${PROJECT_TELOS_PUBLIC}",
              "budget": 700,
              "focus": "index",
              "hops": 0
            },
            "expected_subset": {
              "schema": "project-telos.context-envelope/v1",
              "tool": "index.context.envelope",
              "verification_verdict": "MATCH",
              "selection": {
                "mode": "focused",
                "retained_names": [
                  "index"
                ]
              },
              "freshness": {
                "schema": "index.context-envelope-freshness/v1"
              }
            },
            "rationale": "Catch stale host-loaded Index servers that expose context envelopes without selection summaries and freshness roots."
          }
        ]
      },
      "profiles": {
        "source_checkout": {
          "command": "python",
          "args": [
            "-m",
            "index_graph",
            "mcp"
          ],
          "cwd": "${PROJECT_TELOS_PUBLIC}/index",
          "env": {
            "PYTHONPATH": "${PROJECT_TELOS_PUBLIC}/index/src"
          }
        },
        "package": {
          "command": "index",
          "args": [
            "mcp"
          ]
        }
      }
    },
    "forum": {
      "flagship": "forum",
      "description": "Project Telos orchestration, routing, ledger, and prose server.",
      "expected_tools": [
        "forum.route",
        "forum.ledger.summary",
        "forum.prose.humanize",
        "forum.status",
        "forum.doctor"
      ],
      "auxiliary_tools": [
        "submit",
        "route",
        "plan",
        "status",
        "verify",
        "ledger_get",
        "forum.submit"
      ],
      "freshness": {
        "status_tool": "forum.status",
        "expected_version": "1.12.0",
        "expected_current_status": "1.12.0 per-task context with 28-lane Project Telos roster, model-foundry daemon routing, and MCP parity",
        "failure_codes": [
          "stale_mcp_server",
          "tool_surface_drift",
          "version_drift",
          "behavior_probe_drift",
          "launch_profile_unresolved",
          "freshness_probe_unavailable"
        ],
        "behavior_probes": [
          {
            "id": "forum-broad-telos-route",
            "tool": "forum.route",
            "arguments": {
              "text": "Continue improving the five Project Telos flagship tools as protocol agnostic enterprise AI workflow tools, with MCP CLI compatibility, accessibility, performance, current rendering research, and second brain integration."
            },
            "expected_subset": {
              "decided": "project-telos",
              "needs_escalation": false
            },
            "rationale": "Catch stale host-loaded Forum servers that still escalate broad Project Telos operator work after the decisive-hit router fix."
          }
        ]
      },
      "profiles": {
        "source_checkout": {
          "command": "python",
          "args": [
            "-m",
            "forum.cli",
            "mcp",
            "--ledger",
            "${PROJECT_TELOS_PUBLIC}/.telos/forum-ledger"
          ],
          "cwd": "${PROJECT_TELOS_PUBLIC}/forum",
          "env": {
            "PYTHONPATH": "${PROJECT_TELOS_PUBLIC}/forum/src"
          }
        },
        "package": {
          "command": "forum",
          "args": [
            "mcp"
          ]
        }
      }
    },
    "telos": {
      "flagship": "telos",
      "description": "Project Telos shared room, creative engine, workflow, catalog, and server manifest.",
      "expected_tools": [
        "telos.status",
        "telos.doctor",
        "telos.room",
        "telos.catalog",
        "telos.workflow",
        "telos.server.manifest",
        "telos.mcp.freshness",
        "telos.admission.telemetry",
        "telos.context.envelope",
        "telos.context.pack",
        "telos.action.receipt",
        "telos.loop.ledger",
        "telos.objective.monitor",
        "telos.model.foundry",
        "telos.research.seed",
        "telos.research.thermodynamic",
        "telos.rendering.research",
        "telos.rendering.capabilities",
        "telos.measurement.layers",
        "telos.creative.engine",
        "telos.creative.kernels",
        "telos.revival.registry",
        "telos.display.calibration"
      ],
      "freshness": {
        "status_tool": "telos.status",
        "expected_version": "demo",
        "expected_current_status": "source demo with 51-tool five-flagship catalog, context envelopes, context packs, action receipts, loop ledger, objective monitoring, model foundry, MCP freshness, research seeds, transcript-backed thermodynamic research, rendering research, rendering capabilities, measurement layers, creative engine, creative kernels, revival registry, display calibration, and native Telos MCP surface",
        "failure_codes": [
          "stale_mcp_server",
          "tool_surface_drift",
          "version_drift",
          "behavior_probe_drift",
          "launch_profile_unresolved",
          "freshness_probe_unavailable"
        ]
      },
      "profiles": {
        "source_checkout": {
          "command": "node",
          "args": [
            "${PROJECT_TELOS_PUBLIC}/telos/demo/telos-mcp.mjs"
          ],
          "cwd": "${PROJECT_TELOS_PUBLIC}/telos"
        },
        "package": {
          "command": "node",
          "args": [
            "demo/telos-mcp.mjs"
          ]
        }
      }
    }
  }
}
