  "adapter_interfaces": {
    "assembler": {
      "accepts": "a conformance fixture (happy_path or an operator-supplied fixture)",
      "returns": "a canonical proof packet plus packet_hash over the hash scope"
    },
    "verifier": {
      "accepts": "a proof packet",
      "returns": "named check results, a typed failure list, and a derived verdict MATCH, DRIFT, or UNVERIFIABLE"
    },
    "witness": {
      "accepts": "a source byte path and a view byte path",
      "returns": "the EMET coherence envelope or an unavailability record; never a fabricated verdict"
    },
    "exporter": {
      "accepts": "a proof packet",
      "returns": "a proof-surface agent-action-proof-packet/v0 shaped object"
    }
  },
  "export_contract": {
    "target_schema": "agent-action-proof-packet/v0",
    "proof_surface_root_fields": [
      "version",
      "packet_id",
      "claim",
      "scope",
      "sources",
      "context",
      "actions",
      "admission",
      "side_effects",
      "outputs",
      "evidence_refs",
      "failure_labels",
      "verdicts",
      "uncertainty",
      "decision_summary"
    ],
    "digest_form": "bare-64-hex",
    "context_shape": "plain object summary with workspace and tool_authority, not context_refs[] and no envelope_hash",
    "decision_summary_source": "derived from the packet overall verdict, not from admission.decision",
    "decision_map": {
      "note": "action-receipt policy_decisions to proof-surface ADMISSION_DECISIONS, for the admission[].decision field only",
      "allow": "allow",
      "block": "deny",
      "escalate": "needs-human",
      "require_review": "needs-human"
    },
    "class_map": {
      "note": "action-receipt side_effect_classes to proof-surface SIDE_EFFECT_CLASSES; lossy mappings are disclosed in uncertainty",
      "read": "read",
      "none": "read",
      "write": "write",
      "external_call": "external",
      "human_action": "external",
      "mixed": "external",
      "irreversible_write_or_external": "irreversible"
    },
    "decision_summary_map": {
      "note": "proof-surface overall verdict to decision_summary, from _decision.derive_decision_summary",
      "MATCH": {
        "decision": "approve",
        "confidence": "high"
      },
      "DRIFT": {
        "decision": "block",
        "confidence": "high"
      },
      "UNVERIFIABLE": {
        "decision": "escalate",
        "confidence": "low"
      }
    }
  },
