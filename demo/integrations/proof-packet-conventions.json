{
  "schema": "project-telos.proof-packet/v1",
  "verified_on": "2026-07-02",
  "purpose": "Define an agent-action proof packet: the durable, independently re-checkable justification for one admitted agent action, joining source, context, route, admission, execution, outputs, verification, and an optional witness by reference rather than by copied payload.",
  "sources_checked": [
    {
      "name": "project-telos.action-receipt/v1",
      "path": "demo/integrations/action-receipt-conventions.json",
      "role": "supplies the admission and authority model, side-effect classes, typed stop reasons, and append-only compensation joined by action_id"
    },
    {
      "name": "project-telos.context-envelope/v1",
      "path": "demo/integrations/context-envelope-conventions.json",
      "role": "supplies the source-ref and context-ref shapes joined by id and content hash"
    },
    {
      "name": "project-telos.loop-ledger/v1",
      "path": "demo/integrations/loop-ledger-conventions.json",
      "role": "supplies the optional durable loop join"
    },
    {
      "name": "agent-action-proof-packet/v0",
      "path": "c:/dev/public/proof-surface/src/proof_surface/agent_action/packet.py",
      "commit": "f8380da1c2e10a6719022417281b00704e8c6460",
      "role": "the external export target the exporter conforms to; validated read-only, never imported or spawned at runtime"
    },
    {
      "name": "EMET coherence witness",
      "path": "c:/dev/public/pubscan/emet/impl/js/emet.js",
      "role": "the optional byte-coherence witness stage; spawned when reachable, recorded as unavailable when not, never fabricated"
    }
  ],
  "source_corrections": [
    {
      "target": "spec context mapping row",
      "observed": "proof-surface context is a plain object summary (workspace and tool-authority), not context_refs[], with no envelope_hash field",
      "verdict": "DRIFT",
      "reason": "The working premise mapped context to context_refs[]; proof-surface agent_action/packet.py _validate_context requires a plain object.",
      "resolution": "toProofSurfacePacket emits a plain context object; internal context_refs move to evidence_refs.trace_refs"
    },
    {
      "target": "spec decision_summary mapping row",
      "observed": "proof-surface decision_summary is null-or-derived from the overall MATCH/DRIFT/UNVERIFIABLE verdict, never from admission.decision",
      "verdict": "DRIFT",
      "reason": "The working premise derived decision_summary from admission.decision; proof-surface _decision.derive_decision_summary keys strictly off the overall verdict with DECISION_OUTCOMES {approve, block, rerun, escalate, publish, deploy, archive}.",
      "resolution": "toProofSurfacePacket derives decision_summary from the packet overall verdict with MATCH->approve/high, DRIFT->block/high, UNVERIFIABLE->escalate/low"
    }
  ],
  "contract": {
    "joins_by_reference_only": true,
    "raw_payloads_required": false,
    "digest_references_required": true,
    "admission_before_execution_required": true,
    "compensation_path_required_for_external_writes": true,
    "witness_never_fabricated": true,
    "verdict_derived_not_asserted": true,
    "canonical_hash_excludes_wall_clock": true,
    "verification_required": "Every packet verdict is MATCH, DRIFT, or UNVERIFIABLE."
  },
  "trace_relation": {
    "packet_is_trace_span": false,
    "links_to_trace_span": true,
    "claim": "A trace explains a run. A proof packet justifies one admitted action and survives trace retention, redaction, and export because it carries digests and refs, not raw payloads.",
    "required_join_fields": [
      "admission.action_id",
      "action.action_id",
      "action.event_id",
      "outputs[].digest"
    ]
  },
  "state_model": {
