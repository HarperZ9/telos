    {
      "name": "ATP cURL example",
      "url": "https://github.com/vystartasv/specs/blob/atp-v1.2.0/transaction/v1.2.0/curl.md"
    }
  ],
  "adapter_operations": [
    "/v1/transaction/create-transaction",
    "/v1/transaction/commit",
    "/v1/transaction/compensate",
    "/v1/transaction/{action_id}/status",
    "/v1/transaction/{action_id}/verify"
  ],
  "required_fields": [
    "atp_version",
    "action_id",
    "idempotency_key",
    "guarantee_level",
    "agent_id",
    "input_digest",
    "material_digest",
    "side_effect_class",
    "component_version",
    "config_hash",
    "policy.decision",
    "result.stop_reason",
    "verification.verdict"
  ],
  "allowed_values": {
    "verification_verdicts": [
      "MATCH",
      "DRIFT",
      "UNVERIFIABLE"
    ],
    "side_effect_classes": [
      "read",
      "write",
      "external",
      "human"
    ],
    "policy_decisions": [
      "APPROVED",
      "DENIED",
      "ESCALATED"
    ],
    "stop_reasons": [
      "success",
      "timeout",
      "unauthorized",
      "policy_denied",
      "system_error",
      "user_cancelled",
      "verification_unverifiable",
      "compensated"
    ]
  },
