    "claims_production_readiness": false,
    "requires_live_atp_server": false,
    "signing_anchoring_storage_validated": false,
    "scope_note": "This fixture validates adapter shape against public/synthetic Telos workflows only. It does not certify Haystack, ATP, signing, anchoring, storage, production readiness, or end-to-end interoperability."
  },
  "sources_checked": [
    {
      "name": "Haystack ATP feedback thread",
      "url": "https://github.com/deepset-ai/haystack/issues/11266"
    },
    {
      "name": "ATP v1.2.0 branch",
      "url": "https://github.com/vystartasv/specs/tree/atp-v1.2.0",
      "commit": "7c05f7da950d52a3ceea73d0cd20f66955358629"
    },
    {
      "name": "ATP transaction spec",
      "url": "https://github.com/vystartasv/specs/blob/atp-v1.2.0/transaction.md"
    },
    {
      "name": "ATP TypeScript example",
      "url": "https://github.com/vystartasv/specs/blob/atp-v1.2.0/transaction/v1.2.0/typescript.md"
    },
    {
      "name": "ATP Python example",
      "url": "https://github.com/vystartasv/specs/blob/atp-v1.2.0/transaction/v1.2.0/python.md"
