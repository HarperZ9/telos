{
  "adapter_pipeline": [
    {
      "role": "capture source URL, body hash, local docs, and warning state",
      "stage": "Gather"
    },
    {
      "role": "bind adapter contract to workspace and source-registry context",
      "stage": "Index"
    },
    {
      "role": "route source, domain, legal/license, and proof-packet validation lanes",
      "stage": "Forum"
    },
    {
      "role": "record adapter actions, admission decisions, and loop-ledger receipts",
      "stage": "Telos"
    },
    {
      "role": "reject negative fixtures and verify contract measurements",
      "stage": "Crucible"
    }
  ],
  "boundary": "Pass 0143 defines adapter contracts and fixtures. It does not certify live repository coverage, DOI correctness, full-text access, market uniqueness, theorem proof, or natural-law discovery.",
  "contracts": [
    {
      "adapter": "RepositoryDirectoryAdapter",
      "input_families": [
        "registry_of_repositories",
        "repository_platform",
        "organization_identity"
      ],
      "market_product": "ResearchSourceRouter",
      "outputs": [
        "repository_directory_record",
        "repository_endpoint_candidate",
        "organization_repository_join"
      ],
      "purpose": "Normalize repository-directory and repository-platform evidence into harvestable, source-backed institutional and data repository records.",
      "rejects": [
        "repository listing as complete corpus",
        "endpoint candidate as verified endpoint behavior",
        "organization label as endorsement"
      ],
      "required_fields": [
        "source_system",
        "source_url",
        "directory_record_id",
        "repository_name_ref",
        "repository_home_url",
        "organization_id_ref",
        "organization_type",
