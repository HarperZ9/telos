  "pass": "0146",
  "policy_rules": [
    {
      "action": "honor Retry-After if present; otherwise exponential backoff and lower concurrency",
      "id": "RATE_LIMITED_429",
      "status": "SOURCE_LEAD_ONLY_RETRYABLE"
    },
    {
      "action": "accept HTTP-date or delay-seconds and record the parsed wait",
      "id": "RETRY_AFTER_PARSE",
      "status": "SCHEDULER_REQUIRED"
    },
    {
      "action": "do not tight-loop when a repository omits Retry-After",
      "id": "NO_AUTO_RETRY_ON_HEADERLESS_503",
      "status": "HALT_OR_OPERATOR_POLICY"
    },
    {
      "action": "include mailto or user-agent for Crossref public/polite pool accountability",
      "id": "CROSSREF_POLITE_MAILTO",
      "status": "CONTACTABILITY_REQUIRED"
    },
    {
      "action": "stop retries and record block/support path",
      "id": "CROSSREF_403_BLOCKED",
      "status": "ACCESS_ESCALATION"
    },
    {
      "action": "treat mailto-only OpenAlex polite-pool logic as stale after the API-key shift",
      "id": "OPENALEX_API_KEY_CURRENT",
      "status": "AUTH_POLICY"
    },
    {
      "action": "read rate headers and use exponential backoff on 429",
      "id": "OPENALEX_BACKOFF",
      "status": "SCHEDULER_REQUIRED"
    },
    {
      "action": "prepare client-id field for Q3 2026 rate-limit split",
      "id": "ROR_CLIENT_ID_READY",
      "status": "AUTH_POLICY"
    },
    {
      "action": "route high-volume ROR work to local Docker mirror when needed",
      "id": "ROR_LOCAL_DOCKER_FALLBACK",
      "status": "BULK_FALLBACK"
    },
    {
      "action": "persist token, cursor, completeListSize, and expiration when supplied",
      "id": "OAI_RESUMPTION_TOKEN_CHAIN",
      "status": "PAGINATION_CONTRACT"
    },
    {
      "action": "restart from bounded date/set checkpoint, not from an arbitrary token",
      "id": "OAI_BAD_RESUMPTION_RESTART",
      "status": "CHECKPOINT_REQUIRED"
    },
    {
      "action": "retry root-only context and record selector failure as tool-interface evidence",
      "id": "INDEX_SELECTOR_ROOT_FALLBACK",
      "status": "CONTEXT_SELECTOR_DRIFT"
    }
  ],
