/files/6a33bd3784c6e2b48c7b8571/","meta":{}}},"data":{"id":"6a33bd3784c6e2b48c7b8571","type":"files"}},"review_actions":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/268nb_v1/review_actions/","meta":{}}}},"requests":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/268nb_v1/requests/","meta":{}}}},"affiliated_institutions":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/268nb_v1/institutions/","meta":{}},"self":{"href":"https://api.osf.io/v2/preprints/268nb_v1/relationships/institutions/","meta":{}}}}},"links":{"self":"https://api.osf.io/v2/preprints/268nb_v1/","html":"https://osf.io/preprints/edarxiv/268nb_v1/","preprint_doi":"https://doi.org/10.35542/osf.io/268nb_v1","iri":"https://osf.io/268nb"}},{"id":"ebyhj_v1","type":"preprints","attributes":{"date_created":"2026-03-05T07:14:33.193990","date_modified":"2026-03-16T06:03:11.741734","date_published":"2026-03-16T06:03:11.711093","original_publication_date":null,"custom_publication_citation":null,"doi":null,"title":"Robotics and Artificial Intelligence in Education: Transformations, Challenges, and Future Directions","description":"The integration of artificial intelligence (AI) and robotics into educational settings represents one of the most significant and contested developments in contemporary education. This discussion and opinion paper critically examines the current state of AI and robotics in education, drawing exclusively on peer-reviewed and scholarly literature to analyse research trends, impacts on teaching and learning, AI literacy development, student engagement, learning outcomes, ethical considerations, and policy gaps. The paper argues that while AI and robotics hold considerable transformative potential across all levels of education, their effective and equitable integration requires sustained structural investment, coherent policy frameworks, rigorous teacher preparation, and an unwavering commitment to ethical practice. The review reveals that research in this field remains geographically concentrated, methodologically short-term, and insufficiently attentive to equity, human-centred design, and the broader social implications of automation in education. Recommendations are offered for educators, researchers, policymakers, and institutional leaders seeking to navigate this rapidly evolving landscape responsibly.","is_published":true,"is_preprint_orphan":false,"license_record":null,"tags":[],"preprint_doi_created":null,"date_withdrawn":null,"current_user_permissions":[],"public":true,"reviews_state":"accepted","date_last_transitioned":"2026-03-16T06:03:11.711093","version":1,"is_latest_version":true,"has_coi":false,"conflict_of_interest_statement":null,"has_data_links":"not_applicable","why_no_data":null,"data_links":[],"has_prereg_links":"not_applicable","why_no_prereg":null,"prereg_links":[],"prereg_link_info":null,"default_license_id":"","subjects":[[{"id":"5d0b8ccabe1a2300167c87f3","text":"Education"}]]},"relationships":{"contributors":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/contributors/","meta":{}}}},"bibliographic_contributors":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/bibliographic_contributors/","meta":{}}}},"versions":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/versions/","meta":{}}}},"citation":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/citation/","meta":{}}},"data":{"id":"ebyhj_v1","type":"citation"}},"identifiers":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/identifiers/","meta":{}}}},"node":{"links":{"self":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/relationships/node/","meta":{}}}},"provider":{"links":{"related":{"href":"https://api.osf.io/v2/providers/preprints/edarxiv/","meta":{}}},"data":{"id":"edarxiv","type":"preprint-providers"}},"files":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/ebyhj_v1/files/","meta":{}}}},"primary_file":{"links":{"rela