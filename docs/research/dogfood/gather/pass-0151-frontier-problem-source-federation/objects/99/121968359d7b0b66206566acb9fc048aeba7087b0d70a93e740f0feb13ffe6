s and skills of computational thinking are related. Finally, a proposal is made to link these concepts of the theoretical framework of computational thinking in the official curriculum of a secondary school in the Catalan’s (Spain) education system.","is_published":true,"is_preprint_orphan":false,"license_record":{"copyright_holders":[],"year":null},"tags":["Computational thinking","educational robotics"],"preprint_doi_created":"2025-11-25T04:00:13.564223","date_withdrawn":null,"current_user_permissions":[],"public":true,"reviews_state":"accepted","date_last_transitioned":"2025-11-22T19:36:22.167274","version":1,"is_latest_version":true,"has_coi":false,"conflict_of_interest_statement":null,"has_data_links":"not_applicable","why_no_data":null,"data_links":[],"has_prereg_links":"not_applicable","why_no_prereg":null,"prereg_links":[],"prereg_link_info":null,"default_license_id":"","subjects":[[{"id":"5d0b8ccabe1a2300167c87f3","text":"Education"},{"id":"5d0b8cccbe1a2300167c8818","text":"Secondary Education"}]]},"relationships":{"contributors":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/puakj_v1/contributors/","meta":{}}}},"bibliographic_contributors":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/puakj_v1/bibliographic_contributors/","meta":{}}}},"versions":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/puakj_v1/versions/","meta":{}}}},"citation":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/puakj_v1/citation/","meta":{}}},"data":{"id":"puakj_v1","type":"citation"}},"identifiers":{"links":{"related":{"href":"https://api.osf.io/v2/preprints/puakj_v1/identifiers/","meta":{}}}},"node":{"links":{"related":{"href":"https://api.osf.io/v2/nodes/53rgv/","meta":{}},"self":{"href":"https://api.osf.io/v2/preprints/puakj_v1/relationships/node/","meta":{}}},"data":{"id":"53rgv","type":"nodes"}},"license":{"links":{"related":{"href":"https://api.osf.io/v2/licenses/563c1cf88c5e4a3877f9e96a/","meta":{}}},"data":{"id":"563c1cf8