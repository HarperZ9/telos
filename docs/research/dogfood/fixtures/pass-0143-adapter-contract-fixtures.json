      "reason": "Preprint source state must remain distinct from peer-reviewed publication state."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "repository-count-as-coverage",
      "reason": "Directory count is not corpus completeness or domain coverage."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "organization-label-as-endorsement",
      "reason": "An institution or organization label is identity context, not endorsement or validity."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "open-access-route-as-clearance",
      "reason": "Open-access discovery still needs license, terms, and reuse policy references."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "metadata-only-as-full-text",
      "reason": "Metadata capture is not equivalent to claim body, figures, data, or methods."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "stale-version-as-current",
      "reason": "Version and freshness fields must gate current-state assertions."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "api-docs-as-endpoint-behavior",
      "reason": "API documentation does not prove a particular endpoint was reached and parsed."
    },
    {
      "expected_status": "REJECT",
      "fixture_id": "graph-relation-as-causality",
      "reason": "Citation, relation, and co-occurrence edges are not causal evidence."
    }
