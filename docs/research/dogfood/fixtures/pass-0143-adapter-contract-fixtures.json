{
  "contracts": [
    {
      "adapter": "RepositoryDirectoryAdapter",
      "input_families": [
        "registry_of_repositories",
        "repository_platform",
        "organization_identity"
      ],
      "market_product": "ResearchSourceRouter",
      "outputs": [
        "repository_directory_record",
        "repository_endpoint_candidate",
        "organization_repository_join"
      ],
      "purpose": "Normalize repository-directory and repository-platform evidence into harvestable, source-backed institutional and data repository records.",
      "rejects": [
        "repository listing as complete corpus",
        "endpoint candidate as verified endpoint behavior",
        "organization label as endorsement"
      ],
      "required_fields": [
        "source_system",
        "source_url",
        "directory_record_id",
        "repository_name_ref",
        "repository_home_url",
        "organization_id_ref",
        "organization_type",
        "country_or_region",
        "repository_platform",
        "protocol_candidates",
        "endpoint_url_ref",
        "content_scope",
        "license_or_terms_ref",
        "freshness_time",
        "source_body_sha256",
        "evidence_status",
        "failure_codes",
        "verifier_ref"
      ]
    },
    {
      "adapter": "ScholarlyGraphAdapter",
      "input_families": [
        "scholarly_graph",
        "open_access",
        "preprint_press",
        "biomedical",
        "domain_database",
        "ml_dataset_hub"
      ],
      "market_product": "ClaimToExperimentPacket",
      "outputs": [
        "work_graph_record",
        "claim_context_record",
        "dataset_relation_record"
      ],
      "purpose": "Normalize work, citation, author, dataset, repository-location, funder, license, and version metadata into claim-to-proof packet context.",
      "rejects": [
        "metadata-only as full text",
        "preprint as peer review",
        "graph relation as causality"
      ],
      "required_fields": [
        "source_system",
        "source_url",
        "work_id_ref",
        "doi_ref",
        "title_hash",
        "author_refs",
        "organization_refs",
        "venue_ref",
        "relation_type",
        "reference_refs",
        "citation_refs",
        "dataset_refs",
        "funder_refs",
        "license_or_open_access_state",
        "repository_locations",
        "version_state",
        "freshness_time",
        "source_body_sha256",
        "evidence_status",
        "failure_codes",
        "verifier_ref"
      ]
    }
  ],
  "join_keys": [
    "source_system",
    "source_url",
    "source_body_sha256",
    "record_identifier",
    "repository_identifier",
    "organization_identifier",
